//@version=6
strategy("XAGUSD Trend Double Pullback Stable 20",
     overlay = true,
     initial_capital = 10000,
     default_qty_type = strategy.percent_of_equity,
     default_qty_value = 20,
     commission_type = strategy.commission.percent,
     commission_value = 0.01,
     slippage = 2,
     pyramiding = 0,
     process_orders_on_close = true)

// =========================
// 1. EMA SETTINGS 均线设置
// =========================
groupEMA = "EMA SETTINGS 均线设置"

shortEmaTopLen = input.int(12, "Short EMA 1 Top / 动力", minval = 1, group = groupEMA)
shortEmaBotLen = input.int(25, "Short EMA 2 Bottom / 支撑", minval = 1, group = groupEMA)
mediumEmaTopLen = input.int(50, "Medium EMA 1 Top / 防守", minval = 1, group = groupEMA)
mediumEmaBotLen = input.int(70, "Medium EMA 2 Bottom / 整体", minval = 1, group = groupEMA)
baselineLen = input.int(199, "Baseline / Visual Only", minval = 1, group = groupEMA)

// =========================
// 2. TREND FILTER 趋势过滤
// =========================
groupTrend = "TREND FILTER 趋势过滤"

trendStabilityBars = input.int(20, "Trend Stability Bars / 稳定K线数", minval = 1, group = groupTrend)
cooldownBars = input.int(10, "Signal Cooldown / 信号冷却", minval = 0, group = groupTrend)
breakoutToleranceBars = input.int(5, "Breakout Tolerance Bars / 破位容忍度", minval = 1, group = groupTrend)

// =========================
// 3. 入场过滤
// =========================
groupEntry = "入场过滤"

enableLong = input.bool(true, "允许做多", group = groupEntry)
enableShort = input.bool(true, "允许做空", group = groupEntry)
minBodyAtr = input.float(0.08, "最小实体 ATR倍数", step = 0.01, group = groupEntry)
maxDistanceAtr = input.float(2.2, "距离50EMA最大ATR倍数", step = 0.1, group = groupEntry)

// =========================
// 4. 止盈止损
// =========================
groupRisk = "止盈止损"

atrLen = input.int(14, "ATR周期", minval = 1, group = groupRisk)
slAtr = input.float(1.2, "ATR保护止损倍数", step = 0.1, group = groupRisk)
rr = input.float(1.8, "盈亏比", step = 0.1, group = groupRisk)
swingLen = input.int(8, "结构高低点周期", minval = 1, group = groupRisk)
bufferAtr = input.float(0.3, "结构止损缓冲ATR", step = 0.1, group = groupRisk)

// =========================
// 5. VISUAL SETTINGS 视觉设置
// =========================
groupVisual = "VISUAL SETTINGS 视觉设置"

showTrendBackground = input.bool(true, "Show Trend Background", group = groupVisual)

// =========================
// 6. 均线计算
// =========================
emaShortTop = ta.ema(close, shortEmaTopLen)
emaShortBot = ta.ema(close, shortEmaBotLen)
emaMediumTop = ta.ema(close, mediumEmaTopLen)
emaMediumBot = ta.ema(close, mediumEmaBotLen)
emaBase = ta.ema(close, baselineLen)

shortBandTop = math.max(emaShortTop, emaShortBot)
shortBandBot = math.min(emaShortTop, emaShortBot)

mediumBandTop = math.max(emaMediumTop, emaMediumBot)
mediumBandBot = math.min(emaMediumTop, emaMediumBot)

// =========================
// 7. 趋势结构
// =========================
// 多头排列：12 > 25 > 50 > 70
rawBullTrend = emaShortTop > emaShortBot and emaShortBot > emaMediumTop and emaMediumTop > emaMediumBot

// 空头排列：12 < 25 < 50 < 70
rawBearTrend = emaShortTop < emaShortBot and emaShortBot < emaMediumTop and emaMediumTop < emaMediumBot

bullStableBars = nz(ta.barssince(not rawBullTrend), 100000)
bearStableBars = nz(ta.barssince(not rawBearTrend), 100000)

bullTrend = rawBullTrend and bullStableBars >= trendStabilityBars
bearTrend = rawBearTrend and bearStableBars >= trendStabilityBars

// =========================
// 8. 入场逻辑
// =========================
atr = ta.atr(atrLen)
body = math.abs(close - open)

bodyOk = body >= atr * minBodyAtr

distanceFrom50 = math.abs(close - emaMediumTop) / atr
distanceOk = distanceFrom50 <= maxDistanceAtr

// 多头：回踩 12/25 或 50/70 后，重新站回短期带上方
longShortPullback = ta.lowest(low, breakoutToleranceBars) <= shortBandBot
longMediumPullback = ta.lowest(low, breakoutToleranceBars) <= mediumBandTop
longReclaim = close > shortBandTop and close > open

// 空头：反弹到 12/25 或 50/70 后，重新跌回短期带下方
shortShortPullback = ta.highest(high, breakoutToleranceBars) >= shortBandTop
shortMediumPullback = ta.highest(high, breakoutToleranceBars) >= mediumBandBot
shortReject = close < shortBandBot and close < open

var int lastSignalBar = na
cooldownOk = na(lastSignalBar) or bar_index - lastSignalBar >= cooldownBars

longSignal = enableLong and bullTrend and bodyOk and distanceOk and cooldownOk and longReclaim and (longShortPullback or longMediumPullback) and strategy.position_size <= 0

shortSignal = enableShort and bearTrend and bodyOk and distanceOk and cooldownOk and shortReject and (shortShortPullback or shortMediumPullback) and strategy.position_size >= 0

if longSignal or shortSignal
    lastSignalBar := bar_index

// =========================
// 9. 固定结构止损
// =========================
recentHigh = ta.highest(high, swingLen)[1]
recentLow = ta.lowest(low, swingLen)[1]

var float activeStop = na
var float activeTake = na

if longSignal
    stopByAtr = close - atr * slAtr
    stopByStruct = recentLow - atr * bufferAtr
    finalStop = na(recentLow) ? stopByAtr : math.max(stopByAtr, stopByStruct)
    finalStop := finalStop >= close ? stopByAtr : finalStop

    risk = close - finalStop

    activeStop := finalStop
    activeTake := close + risk * rr

    strategy.entry("Buy", strategy.long)

if shortSignal
    stopByAtr = close + atr * slAtr
    stopByStruct = recentHigh + atr * bufferAtr
    finalStop = na(recentHigh) ? stopByAtr : math.min(stopByAtr, stopByStruct)
    finalStop := finalStop <= close ? stopByAtr : finalStop

    risk = finalStop - close

    activeStop := finalStop
    activeTake := close - risk * rr

    strategy.entry("Sell", strategy.short)

if strategy.position_size > 0
    strategy.exit("Buy Exit", "Buy", stop = activeStop, limit = activeTake)

if strategy.position_size < 0
    strategy.exit("Sell Exit", "Sell", stop = activeStop, limit = activeTake)

if strategy.position_size == 0 and not longSignal and not shortSignal
    activeStop := na
    activeTake := na

// =========================
// 10. 图表显示
// =========================
pShortTop = plot(emaShortTop, "EMA 12 动力", color = color.new(color.fuchsia, 0), linewidth = 2)
pShortBot = plot(emaShortBot, "EMA 25 支撑", color = color.new(color.fuchsia, 35), linewidth = 2)

fill(
     pShortTop,
     pShortBot,
     color = emaShortTop >= emaShortBot ? color.new(color.green, 82) : color.new(color.red, 82),
     title = "短期趋势彩带"
)

pMediumTop = plot(emaMediumTop, "EMA 50 防守", color = color.new(color.orange, 0), linewidth = 2)
pMediumBot = plot(emaMediumBot, "EMA 70 整体", color = color.new(color.orange, 35), linewidth = 2)

fill(
     pMediumTop,
     pMediumBot,
     color = emaMediumTop >= emaMediumBot ? color.new(color.orange, 85) : color.new(color.red, 87),
     title = "中期趋势彩带"
)

plot(emaBase, "EMA 199 Baseline", color = color.new(color.purple, 0), linewidth = 2)

// 趋势背景
bgcolor(
     showTrendBackground and bullTrend ? color.new(color.green, 90) :
     showTrendBackground and bearTrend ? color.new(color.red, 90) :
     na
)

// 买卖点
plotshape(
     longSignal,
     title = "买点",
     text = "买",
     style = shape.labelup,
     location = location.belowbar,
     color = color.new(color.green, 0),
     textcolor = color.white,
     size = size.tiny
)

plotshape(
     shortSignal,
     title = "卖点",
     text = "卖",
     style = shape.labeldown,
     location = location.abovebar,
     color = color.new(color.red, 0),
     textcolor = color.white,
     size = size.tiny
)

// =========================
// 11. 警报
// =========================
alertcondition(longSignal, title = "XAGUSD 买点提醒", message = "XAGUSD 出现 Trend Double Pullback 买点")
alertcondition(shortSignal, title = "XAGUSD 卖点提醒", message = "XAGUSD 出现 Trend Double Pullback 卖点")
